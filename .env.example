# Server-only: never sent to the browser. Used by BFF proxy and login/logout route handlers.
API_ORIGIN=https://api.dev.gadaapp.com

# Browser-facing base URL — points at the same-origin BFF proxy, NOT directly at the API.
# The generated client appends spec paths (which already include /v1), so:
#   /api/gada + /v1/admin/events → /api/gada/v1/admin/events → proxied to API_ORIGIN/v1/admin/events
NEXT_PUBLIC_API_BASE_URL=/api/gada
